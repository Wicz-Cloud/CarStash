# CarStash — environment configuration
# Copy to .env and fill in your values
# Never commit .env to git

# ── Server settings ───────────────────────────────────────────────────────────

# IP address of the Raspberry Pi on your local network
PI_IP=192.168.1.100

# Port the CarStash client agent listens on (default: 5001)
PI_PORT=5001

# Where the server caches transcoded files
# These persist across restarts — delete to force re-encode
PLEXSYNC_CACHE=/tmp/carstash_cache

# Where the server persists queue state across restarts
PLEXSYNC_STATE=queue_state.json

# ── Client settings (set on the Pi, not the server) ──────────────────────────

# Which media server runs on the Pi
# Options: plex | jellyfin | emby | kodi | none
CARSTASH_MEDIA_SERVER=none

# Directory where received media files are stored
# Point your media server library at this path
CARSTASH_MEDIA_DIR=/mnt/carstash/media

# Minimum free space to maintain on the Pi (GB)
# LRU eviction kicks in when free space drops below this
CARSTASH_MIN_FREE_GB=2

# ── Media server connection (set on the Pi) ───────────────────────────────────

# Override the default URL for your media server
# Defaults: plex=:32400, jellyfin=:8096, emby=:8096, kodi=:8080
MEDIA_SERVER_URL=

# API token / password for your media server
# See docs/MEDIA_SERVERS.md for how to get this per server
MEDIA_SERVER_TOKEN=

# Library section ID (Plex) or item ID (Jellyfin/Emby)
# Leave blank to refresh all libraries
# Not used for Kodi
MEDIA_SERVER_SECTION=

# Kodi HTTP username (default: kodi)
KODI_USER=kodi

# ── Auth token for client/server mutual authentication ───────────────
# Set this to the same value on both server and client
CARSTASH_AUTH_TOKEN=changeme123
